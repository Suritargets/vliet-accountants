# Neon Postgres (pooled connection string)
DATABASE_URL=

# HMAC key for admin session cookies (32+ random bytes, hex)
SESSION_SECRET=

# Single admin login for /admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Vercel Blob (image uploads in the CMS)
BLOB_READ_WRITE_TOKEN=

# Email notifications (booking system). Leave MAIL_PROVIDER empty to disable
# sending entirely — safe default for local development.
MAIL_PROVIDER=
MAIL_FROM=
OFFICE_NOTIFICATION_EMAIL=

# SMTP path (MAIL_PROVIDER=smtp) — Microsoft 365 mailbox via smtp.office365.com.
# Requires "Authenticated SMTP" enabled on the mailbox in the Exchange admin
# center; may be blocked entirely by tenant-wide Conditional Access.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Graph path (MAIL_PROVIDER=graph) — Microsoft Graph API, bypasses SMTP AUTH
# entirely (client-credentials OAuth2, not SMTP). Requires an Entra ID app
# registration with the Mail.Send Application permission (admin-consented)
# and an Exchange Online Application Access Policy scoping that app to
# GRAPH_SENDER_MAILBOX specifically — otherwise Graph returns 403.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_MAILBOX=info@vlietaccountants.com
